# =====================================================================
# Cast Loop - variables d'environnement
# Copier vers `.env.local` (racine) pour un dev local, puis remplir.
# =====================================================================

# ---------- Frontend (exposees au navigateur via NEXT_PUBLIC_*) -------
# URL du projet Supabase (ex: https://xxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
# Anon key Supabase (clef publique, peut etre exposee au client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# URL publique de l'API NestJS (inclut le prefixe /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# ---------- Backend API (apps/api) -----------------------------------
# Port d'ecoute de l'API (defaut 4000)
API_PORT=4000

# Chaine Postgres. Preferer le "Session pooler" Supabase pour un backend
# Node persistant sur un reseau IPv4 (la connexion directe est IPv6-only
# et peut lever EHOSTUNREACH).
# Exemple:
# postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=

# Meme URL que NEXT_PUBLIC_SUPABASE_URL (cote serveur).
SUPABASE_URL=
# Service role key Supabase — SECRET, ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=
# Bucket Storage utilise pour les medias des posts.
SUPABASE_STORAGE_BUCKET=cast-loop-media

# Clef de chiffrement symetrique (base64, 32 octets) pour les tokens
# OAuth des comptes sociaux stockes en base. Generer avec:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# "mock" pour simuler les publications sociales en dev,
# "live" pour appeler les vraies APIs Meta / LinkedIn.
SOCIAL_PUBLISH_MODE=mock

# ---------- Connexions OAuth sociales --------------------------------
# URL publique du frontend utilisee par le backend pour rediriger apres
# le callback OAuth.
APP_WEB_URL=http://localhost:3001

# App LinkedIn pour profil perso (OIDC + Share on LinkedIn).
LINKEDIN_MEMBER_CLIENT_ID=
LINKEDIN_MEMBER_CLIENT_SECRET=
# Exemple local: http://localhost:4000/api/v1/social-auth/linkedin/callback
LINKEDIN_MEMBER_REDIRECT_URI=

# App LinkedIn pour Pages/organizations.
LINKEDIN_ORG_CLIENT_ID=
LINKEDIN_ORG_CLIENT_SECRET=
# Exemple local: http://localhost:4000/api/v1/social-auth/linkedin/callback
LINKEDIN_ORG_REDIRECT_URI=

# Version de l'API LinkedIn REST pour les endpoints organizations.
# Laisser vide si vous preferez l'imposer par environnement.
LINKEDIN_API_VERSION=

# Application Meta (Facebook Login / Graph API).
META_APP_ID=
META_APP_SECRET=
# Exemple local: http://localhost:4000/api/v1/social-auth/meta/callback
META_REDIRECT_URI=
META_API_VERSION=v21.0

# Rappels Telegram pour les cibles "connect_only".
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
